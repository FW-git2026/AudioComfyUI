# =============================================
# ComfyUI 项目专用 .gitignore 文件
# 作用：忽略不必要的缓存、模型、日志、临时文件、IDE配置等
# =============================================

# ===== Python 相关 =====
__pycache__/                  # Python 字节码缓存目录
*.py[cod]                     # Python 编译生成的字节码文件（.pyc, .pyo, .pyd）
*.pyo
*.pyd

# ===== 模型文件（大文件，不应该提交到 Git） =====
#*.ckpt                        # ComfyUI 模型文件（通常很大）
#*.safetensors                 # 安全张量模型文件
#*.pth                         # PyTorch 模型
#*.onnx                        # ONNX 模型
#*.bin                         # 通用二进制模型文件
#*.zip                         # 打包的模型或数据
#*.tar.gz                      # 压缩包
#/models/                      # 模型存放目录（通常整个目录都很大，不提交）
/output/                      # 推理输出目录（生成的图像/视频等）

# ===== 临时文件 & 缓存 =====
/temp/
/tmp/
*.tmp
*.cache
*.log                         # 日志文件
*.pid
*.pid.lock

# ===== 虚拟环境 =====
venv/                         # Python 虚拟环境目录（常见命名）
.venv/                        # 另一种常见虚拟环境目录
/env/
/.env                         # 环境变量配置文件（通常含敏感信息，可选忽略）

# ===== IDE & 编辑器配置（本地个性化，不应该提交） =====
.vs/
.vscode/
.idea/
*.swp
*.swo

# ===== 前端 / Web 构建产物（通常自动生成） =====
/web/
/web/extensions/
/web/build/
/web/dist/
/static/
#/assets/

# ===== 自定义节点（通常需要提交！除非你明确要忽略某些） =====
# 如果你有不想提交的示例节点，可以单独 ignore，但一般不忽略整个 custom_nodes/
# /custom_nodes/
# !custom_nodes/example_node.py

# ===== 其他常见忽略项 =====
.DS_Store                     # macOS 索引文件
Thumbs.db                     # Windows 缩略图缓存
*.user
*.example                     # 示例文件（如果你不想提交某些示例）
#extra_model_paths.yaml        # 用户自定义模型路径（个性化配置）
openapi.yaml
filtered-openapi.yaml
uv.lock                       # uv 工具依赖锁文件（类似 pip freeze）

# ===== 测试或 UI 相关（按需忽略） =====
/tests-ui/
/tests-ui/data/
#*.json                        # 某些测试数据文件（按需）
